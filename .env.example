# Base URL of the MyBrain ingest API the bundled plugin will point at.
# Read by esbuild at build time and inlined into main.js as the default
# value of the "Ingest endpoint" setting; users can still override it in
# the plugin's settings tab. Required — the build fails fast if unset.
#
# In CI, set this as a repo-level variable in GitHub:
#   Settings → Secrets and variables → Actions → Variables
# Locally, copy this file to `.env` and source it before `npm run build`,
# or just `MYBRAIN_API_BASE=... npm run build`.
MYBRAIN_API_BASE=https://api.mybrain.ai/integrations/obsidian
